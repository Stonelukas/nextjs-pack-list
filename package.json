{
  "name": "pack-list",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run --project client",
    "test:watch": "NODE_OPTIONS=--no-experimental-webstorage vitest --project client",
    "test:convex": "NODE_OPTIONS=--no-experimental-webstorage vitest run --project convex --pool=forks --maxWorkers=1",
    "test:e2e": "playwright test",
    "test:build-smoke": "bun scripts/smoke-built-artifact.ts",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:ci": "playwright install --with-deps chromium",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
