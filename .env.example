# Public Vite browser/build values
# Vite embeds every VITE_* value in client JavaScript.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Optional Convex CLI-managed local metadata for HTTP actions/webhooks.
# The application does not consume this value and Vercel does not require it.
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional public browser values
# Omit VITE_APP_URL to use window.location.origin.
VITE_APP_URL=http://localhost:5173
VITE_SENTRY_DSN=

# Local Convex project linkage
# Usually written/managed by the Convex setup flow; do not invent a value.
CONVEX_DEPLOYMENT=dev:your-deployment

# Target-scoped Convex production release credential
# Load only in the approved backend release job/operator shell.
# Repository CI and the Vercel static build do not use this value.
CONVEX_DEPLOY_KEY=

# Convex deployment environment values
# Set these in Convex, not in the Vite bundle and never with a VITE_ prefix.
CLERK_JWT_ISSUER_DOMAIN=https://your-exact-clerk-issuer.example
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
